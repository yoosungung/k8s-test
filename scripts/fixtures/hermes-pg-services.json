        "selector": { "app.kubernetes.io/name": "postgresql" }
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "ingress-nginx-controller",
        "namespace": "ingress-nginx",
        "labels": { "app.kubernetes.io/name": "ingress-nginx" }
      },
      "spec": {
        "ports": [{ "name": "postgres-tcp", "port": 5432, "targetPort": 5432 }]
      }
    },
    {
      "apiVersion": "v1",
      "kind": "Service",
      "metadata": {
        "name": "postgres",
        "namespace": "runtime",
